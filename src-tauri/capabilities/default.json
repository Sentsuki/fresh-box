{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:path:allow-resolve",
    {
      "identifier": "core:default",
      "description": "Allow executing the bundled sing-box binary as a sidecar",
      "allow": [
        {
          "name": "shell:execute",
          "cmd": "$RESOURCE/bin/sing-box.exe",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}